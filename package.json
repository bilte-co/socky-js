{
  "name": "@bilte-co/socky-js",
  "version": "0.6.1",
  "description": "JavaScript SDK for the Socky Flights API",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "aube@1.15.0",
  "private": false,
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bilte-co/socky-js.git"
  },
  "bugs": {
    "url": "https://github.com/bilte-co/socky-js/issues"
  },
  "homepage": "https://github.com/bilte-co/socky-js#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepack": "aubr clean && aubr build && aubr typecheck",
    "changeset": "changeset",
    "test": "echo \"(no tests yet)\""
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@types/node": "20.12.12",
    "eslint": "10.3.0",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "author": "Bilte Co"
}
