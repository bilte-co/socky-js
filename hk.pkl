amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"

local linters = new Mapping<String, Step> {
    ["eslint"] {
        glob = List("*.ts")
        exclude = List("dist/**", "node_modules/**")
        check = "aube exec eslint {{files}}"
        fix = "aube exec eslint --fix {{files}}"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["pre-push"] {
        steps {
            ["eslint"] = linters["eslint"]
            ["typecheck"] {
                glob = List("*.ts")
                exclude = List("dist/**", "node_modules/**")
                check = "aube exec tsc -- --noEmit"
            }
        }
    }
}
